{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Matugen Frosted Glass",
  "author": "OpenCode",
  "themes": [
    {
      "name": "Matugen Frosted Glass",
      "appearance": "dark",
      "style": {
        "background": "#13131599",
        "editor.background": "#13131599",
        "editor.gutter.background": "#13131570",
        "editor.foreground": "#e4e2e3",
        "panel.background": "#1b1b1d8A",
        "surface.background": "#1f1f218A",
        "elevated_surface.background": "#2a2a2bA8",
        "status_bar.background": "#1f1f217A",
        "title_bar.background": "#1f1f217A",
        "toolbar.background": "#1f1f217A",
        "tab_bar.background": "#1313157A",
        "tab.inactive_background": "#13131552",
        "tab.active_background": "#2a2a2bA0",
        "editor.active_line.background": "#2a2a2b4D",
        "editor.active_line_number": "#c1c6d6",
        "editor.line_number": "#929092",
        "editor.wrap_guide": "#47464866",
        "editor.active_wrap_guide": "#c1c6d680",
        "editor.indent_guide": "#47464866",
        "editor.indent_guide_active": "#c1c6d680",
        "editor.invisible": "#92909255",
        "editor.document_highlight.read_background": "#c1c6d626",
        "editor.document_highlight.write_background": "#bec6dc30",

        "border": "#47464880",
        "border.variant": "#47464866",
        "border.focused": "#c1c6d6AA",
        "border.selected": "#c1c6d699",
        "border.transparent": "#47464800",
        "border.disabled": "#47464840",

        "text": "#e4e2e3",
        "text.muted": "#929092",
        "text.placeholder": "#929092AA",
        "text.accent": "#c1c6d6",
        "text.disabled": "#92909288",

        "icon": "#929092",
        "icon.accent": "#c1c6d6",
        "icon.muted": "#929092AA",
        "icon.disabled": "#92909280",

        "accents": ["#c1c6d6"],
        "created": "#6bd67b",
        "deleted": "#ffb4ab",
        "modified": "#c1c6d6",
        "error": "#ffb4ab",
        "warning": "#c4c6d0",
        "success": "#6bd67b",
        "info": "#bec6dc",
        "hint": "#929092",

        "search.match_background": "#41475366",
        "search.match_border": "#c1c6d6AA",
        "search.active_match_background": "#41475388",
        "search.active_match_border": "#c1c6d6",

        "element.background": "#1b1b1d8C",
        "element.hover": "#2a2a2bA8",
        "element.active": "#353436BF",
        "element.selected": "#2a2a2bA8",
        "element.disabled": "#1f1f2166",

        "input.background": "#1b1b1d99",
        "input.border": "#47464880",
        "input.border.focused": "#c1c6d6AA",
        "button.background": "#1f1f21A8",
        "button.border": "#47464899",
        "button.border.focused": "#c1c6d6CC",
        "button.border.hover": "#c1c6d6AA",

        "terminal.background": "#13131599",
        "terminal.foreground": "#e4e2e3",
        "terminal.ansi.black": "#131315",
        "terminal.ansi.red": "#f66e93",
        "terminal.ansi.green": "#6bd67b",
        "terminal.ansi.yellow": "#fff872",
        "terminal.ansi.blue": "#b3b9cb",
        "terminal.ansi.magenta": "#515563",
        "terminal.ansi.cyan": "#c1c6d6",
        "terminal.ansi.white": "#d3d6e0",
        "terminal.ansi.bright_black": "#80828b",
        "terminal.ansi.bright_red": "#ff9fb9",
        "terminal.ansi.bright_green": "#a5ffb3",
        "terminal.ansi.bright_yellow": "#fffba5",
        "terminal.ansi.bright_blue": "#d7dceb",
        "terminal.ansi.bright_magenta": "#edf1ff",
        "terminal.ansi.bright_cyan": "#f3f6ff",
        "terminal.ansi.bright_white": "#f8faff",

        "syntax": {
          "attribute": { "color": "#b3b9cb" },
          "boolean": { "color": "#d7dceb" },
          "comment": { "color": "#80828b", "font_style": "italic" },
          "constant": { "color": "#d7dceb" },
          "constructor": { "color": "#6bd67b" },
          "function": { "color": "#c1c6d6" },
          "keyword": { "color": "#c1c6d6" },
          "number": { "color": "#d7dceb" },
          "operator": { "color": "#929092" },
          "property": { "color": "#b3b9cb" },
          "punctuation": { "color": "#c8c6c7" },
          "string": { "color": "#fff872" },
          "string.escape": { "color": "#c1c6d6" },
          "tag": { "color": "#c1c6d6" },
          "title": { "color": "#c1c6d6", "font_weight": 700 },
          "type": { "color": "#b3b9cb" },
          "variable": { "color": "#f8faff" },
          "variable.special": { "color": "#d7dceb" }
        }
      }
    }
  ]
}
