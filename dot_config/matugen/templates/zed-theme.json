{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Matugen Frosted Glass",
  "author": "OpenCode",
  "themes": [
    {
      "name": "Matugen Frosted Glass",
      "appearance": "dark",
      "style": {
        "background": "{{colors.background.dark.hex}}99",
        "editor.background": "{{colors.background.dark.hex}}99",
        "editor.gutter.background": "{{colors.background.dark.hex}}70",
        "editor.foreground": "{{colors.on_surface.dark.hex}}",
        "panel.background": "{{colors.surface_container_low.dark.hex}}8A",
        "surface.background": "{{colors.surface_container.dark.hex}}8A",
        "elevated_surface.background": "{{colors.surface_container_high.dark.hex}}A8",
        "status_bar.background": "{{colors.surface_container.dark.hex}}7A",
        "title_bar.background": "{{colors.surface_container.dark.hex}}7A",
        "toolbar.background": "{{colors.surface_container.dark.hex}}7A",
        "tab_bar.background": "{{colors.background.dark.hex}}7A",
        "tab.inactive_background": "{{colors.background.dark.hex}}52",
        "tab.active_background": "{{colors.surface_container_high.dark.hex}}A0",
        "editor.active_line.background": "{{colors.surface_container_high.dark.hex}}4D",
        "editor.active_line_number": "{{colors.primary.dark.hex}}",
        "editor.line_number": "{{colors.outline.dark.hex}}",
        "editor.wrap_guide": "{{colors.outline_variant.dark.hex}}66",
        "editor.active_wrap_guide": "{{colors.primary.dark.hex}}80",
        "editor.indent_guide": "{{colors.outline_variant.dark.hex}}66",
        "editor.indent_guide_active": "{{colors.primary.dark.hex}}80",
        "editor.invisible": "{{colors.outline.dark.hex}}55",
        "editor.document_highlight.read_background": "{{colors.primary.dark.hex}}26",
        "editor.document_highlight.write_background": "{{colors.tertiary.dark.hex}}30",

        "border": "{{colors.outline_variant.dark.hex}}80",
        "border.variant": "{{colors.outline_variant.dark.hex}}66",
        "border.focused": "{{colors.primary.dark.hex}}AA",
        "border.selected": "{{colors.primary.dark.hex}}99",
        "border.transparent": "{{colors.outline_variant.dark.hex}}00",
        "border.disabled": "{{colors.outline_variant.dark.hex}}40",

        "text": "{{colors.on_surface.dark.hex}}",
        "text.muted": "{{colors.outline.dark.hex}}",
        "text.placeholder": "{{colors.outline.dark.hex}}AA",
        "text.accent": "{{colors.primary.dark.hex}}",
        "text.disabled": "{{colors.outline.dark.hex}}88",

        "icon": "{{colors.outline.dark.hex}}",
        "icon.accent": "{{colors.primary.dark.hex}}",
        "icon.muted": "{{colors.outline.dark.hex}}AA",
        "icon.disabled": "{{colors.outline.dark.hex}}80",

        "accents": ["{{colors.primary.dark.hex}}"],
        "created": "{{dank16.color2.dark.hex}}",
        "deleted": "{{colors.error.dark.hex}}",
        "modified": "{{colors.primary.dark.hex}}",
        "error": "{{colors.error.dark.hex}}",
        "warning": "{{colors.secondary.dark.hex}}",
        "success": "{{dank16.color2.dark.hex}}",
        "info": "{{colors.tertiary.dark.hex}}",
        "hint": "{{colors.outline.dark.hex}}",

        "search.match_background": "{{colors.primary_container.dark.hex}}66",
        "search.match_border": "{{colors.primary.dark.hex}}AA",
        "search.active_match_background": "{{colors.primary_container.dark.hex}}88",
        "search.active_match_border": "{{colors.primary.dark.hex}}",

        "element.background": "{{colors.surface_container_low.dark.hex}}8C",
        "element.hover": "{{colors.surface_container_high.dark.hex}}A8",
        "element.active": "{{colors.surface_container_highest.dark.hex}}BF",
        "element.selected": "{{colors.surface_container_high.dark.hex}}A8",
        "element.disabled": "{{colors.surface_container.dark.hex}}66",

        "input.background": "{{colors.surface_container_low.dark.hex}}99",
        "input.border": "{{colors.outline_variant.dark.hex}}80",
        "input.border.focused": "{{colors.primary.dark.hex}}AA",
        "button.background": "{{colors.surface_container.dark.hex}}A8",
        "button.border": "{{colors.outline_variant.dark.hex}}99",
        "button.border.focused": "{{colors.primary.dark.hex}}CC",
        "button.border.hover": "{{colors.primary.dark.hex}}AA",

        "terminal.background": "{{colors.background.dark.hex}}99",
        "terminal.foreground": "{{colors.on_surface.dark.hex}}",
        "terminal.ansi.black": "{{dank16.color0.dark.hex}}",
        "terminal.ansi.red": "{{dank16.color1.dark.hex}}",
        "terminal.ansi.green": "{{dank16.color2.dark.hex}}",
        "terminal.ansi.yellow": "{{dank16.color3.dark.hex}}",
        "terminal.ansi.blue": "{{dank16.color4.dark.hex}}",
        "terminal.ansi.magenta": "{{dank16.color5.dark.hex}}",
        "terminal.ansi.cyan": "{{dank16.color6.dark.hex}}",
        "terminal.ansi.white": "{{dank16.color7.dark.hex}}",
        "terminal.ansi.bright_black": "{{dank16.color8.dark.hex}}",
        "terminal.ansi.bright_red": "{{dank16.color9.dark.hex}}",
        "terminal.ansi.bright_green": "{{dank16.color10.dark.hex}}",
        "terminal.ansi.bright_yellow": "{{dank16.color11.dark.hex}}",
        "terminal.ansi.bright_blue": "{{dank16.color12.dark.hex}}",
        "terminal.ansi.bright_magenta": "{{dank16.color13.dark.hex}}",
        "terminal.ansi.bright_cyan": "{{dank16.color14.dark.hex}}",
        "terminal.ansi.bright_white": "{{dank16.color15.dark.hex}}",

        "syntax": {
          "attribute": { "color": "{{dank16.color4.dark.hex}}" },
          "boolean": { "color": "{{dank16.color12.dark.hex}}" },
          "comment": { "color": "{{dank16.color8.dark.hex}}", "font_style": "italic" },
          "constant": { "color": "{{dank16.color12.dark.hex}}" },
          "constructor": { "color": "{{dank16.color2.dark.hex}}" },
          "function": { "color": "{{colors.primary.dark.hex}}" },
          "keyword": { "color": "{{dank16.color6.dark.hex}}" },
          "number": { "color": "{{dank16.color12.dark.hex}}" },
          "operator": { "color": "{{colors.outline.dark.hex}}" },
          "property": { "color": "{{dank16.color4.dark.hex}}" },
          "punctuation": { "color": "{{colors.on_surface_variant.dark.hex}}" },
          "string": { "color": "{{dank16.color3.dark.hex}}" },
          "string.escape": { "color": "{{dank16.color6.dark.hex}}" },
          "tag": { "color": "{{dank16.color6.dark.hex}}" },
          "title": { "color": "{{colors.primary.dark.hex}}", "font_weight": 700 },
          "type": { "color": "{{dank16.color4.dark.hex}}" },
          "variable": { "color": "{{dank16.color15.dark.hex}}" },
          "variable.special": { "color": "{{dank16.color12.dark.hex}}" }
        }
      }
    }
  ]
}
